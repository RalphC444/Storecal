# Copy to .env for local dev, or set these as environment variables in Render.
# NEVER commit the real .env (it's gitignored).

# MongoDB Atlas connection string.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# Which shop the API falls back to when a request has no login and no ?key=/?slug=.
SHOP_SLUG=default

# Local API port (Render sets PORT automatically — leave unset in production).
PORT=5001

# Secret for signing auth/invite/reset JWTs. Use a long random string in prod.
JWT_SECRET=change-me-to-a-long-random-string

# Set to "production" on Render so auth cookies are marked Secure (HTTPS-only).
NODE_ENV=development

# Stripe (test or live). Billing portal + checkout use the secret key.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Optional — enable transactional email (provider invites + password resets).
# RESEND_API_KEY=re_xxx
# EMAIL_FROM="StoreCal <noreply@yourdomain.com>"

# Absolute base URL of the app, used to build customer "manage your appointment"
# links (reschedule/cancel). Falls back to the request origin if unset; set it
# explicitly in production. e.g. https://www.storecal.com
# PUBLIC_URL=https://www.storecal.com

# Optional — enable SMS confirmations + the reschedule/cancel link by text.
# Need the Account SID, an SMS-capable Twilio number, and ONE credential pair:
#   • the Auth Token, OR  • an API Key (SK...) + its secret.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
# TWILIO_FROM=+1XXXXXXXXXX
# TWILIO_AUTH_TOKEN=your_auth_token
# --- or, instead of the auth token ---
# TWILIO_API_KEY=SKxxxxxxxxxxxxxxxx
# TWILIO_API_SECRET=your_api_key_secret
